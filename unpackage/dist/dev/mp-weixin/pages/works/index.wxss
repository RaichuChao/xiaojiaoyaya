.u-wrap.data-v-b0782d84 {
  height: 100vh;
  display: flex;
  flex-direction: column;
}
.u-menu-wrap.data-v-b0782d84 {
  flex: 1;
  display: flex;
  overflow: hidden;
}
.u-tab-view.data-v-b0782d84 {
  width: 200rpx;
  height: 100%;
}
.u-tab-item.data-v-b0782d84 {
  height: 110rpx;
  background: #f6f6f6;
  box-sizing: border-box;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 26rpx;
  color: #444;
  font-weight: 400;
  line-height: 1;
}
.u-tab-item-active.data-v-b0782d84 {
  position: relative;
  color: #000;
  font-size: 30rpx;
  font-weight: 600;
  background: #fff;
}
.u-tab-item-active.data-v-b0782d84::before {
  content: "";
  position: absolute;
  border-left: 4px solid var(--up-primary, var(--u-primary, #3c9cff));
  height: 32rpx;
  left: 0;
  top: 39rpx;
}
.right-box.data-v-b0782d84 {
  background-color: #fafafa;
}
.page-view.data-v-b0782d84 {
  background-color: #fff;
  min-height: 100vh;
  padding: 16rpx;
}
.class-item.data-v-b0782d84 {
  margin-bottom: 30rpx;
  background-color: #fff;
  padding: 16rpx 0;
  border-radius: 8rpx;
}
.item-title.data-v-b0782d84 {
  font-size: 26rpx;
  color: var(--up-main-color, var(--u-main-color, #303133));
  font-weight: bold;
}
.item-menu-name.data-v-b0782d84 {
  font-weight: normal;
  font-size: 24rpx;
  color: var(--up-main-color, var(--u-main-color, #303133));
  margin-top: 8rpx;
  text-align: center;
}
.item-container.data-v-b0782d84 {
  display: flex;
  flex-wrap: wrap;
  /* 关键：让两张图片平分剩余空间 */
  justify-content: space-between;
}

/* 图片容器优化：固定宽度 + 居中 */
.thumb-box.data-v-b0782d84 {
  /* 不用 50%，用 calc 留出间隙 */
  width: calc(50% - 5rpx);
  display: flex;
  align-items: center;
  justify-content: flex-start;
  flex-direction: column;
  margin-top: 20rpx;
}

/* 图片外层：固定宽高比，防止拉伸 */
.img-wrapper.data-v-b0782d84 {
  width: 100%;
  display: block;
  /* 统一图片高度，更美观 */
  min-height: 200rpx;
}

/* 图片样式：铺满容器，不变形 */
.item-menu-image.data-v-b0782d84 {
  width: 100%;
  height: 100%;
  object-fit: cover;
  /* 兼容多端，保证不变形 */
}
.empty-box.data-v-b0782d84 {
  display: flex;
  justify-content: center;
  padding: 80rpx 0;
}