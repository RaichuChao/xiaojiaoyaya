
.photo-container.data-v-1cf27b2a {
  background-color: #fff;
  min-height: 100vh;
}

/* 轮播图样式 */
.u-swiper.data-v-1cf27b2a {
  height: 420rpx;
}

/* 通用标题样式 */
.section-wrap.data-v-1cf27b2a {
  padding: 40rpx 0;
}
.section-title.data-v-1cf27b2a {
  text-align: center;
  margin-bottom: 30rpx;
}
.title-cn.data-v-1cf27b2a {
  display: block;
  font-size: 36rpx;
  font-weight: 500;
  color: #222;
}
.title-en.data-v-1cf27b2a {
  display: block;
  font-size: 24rpx;
  color: #999;
  margin-top: 10rpx;
}

/* 分类网格 */
.category-grid.data-v-1cf27b2a {
  display: grid;
  grid-template-columns: repeat(2, 1fr);
  gap: 10rpx;
}
.grid-item.data-v-1cf27b2a {
  position: relative;

  overflow: hidden;
}
.grid-mask.data-v-1cf27b2a {
	
  position: absolute;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  display: flex;
  flex-direction: column;
  justify-content: center;
  align-items: center;
  color: #fff;
  background-color: rgba(0, 0, 0, 0.4);
  width: 100%;
  height: 100%
}
.grid-cn.data-v-1cf27b2a {
  font-size: 30rpx;
  font-weight: 500;
}
.grid-en.data-v-1cf27b2a {
  font-size: 22rpx;
  margin-top: 8rpx;
  opacity: 0.8;
}

/* 视频列表 */
.video-list.data-v-1cf27b2a {
  display: flex;
  flex-direction: column;
  gap: 30rpx;
}
.video-item.data-v-1cf27b2a {
  border-radius: 12rpx;
  overflow: hidden;
}
.video-player.data-v-1cf27b2a {
  width: 100%;
  height: 380rpx;
}
.video-title.data-v-1cf27b2a {
  display: block;
  padding: 20rpx;
  font-size: 28rpx;
  color: #333;
  background-color: #f8f8f8;
}
