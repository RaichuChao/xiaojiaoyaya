}
.category-grid.data-v-1cf27b2a {
  display: grid;
  grid-template-columns: repeat(2, 1fr);
  gap: 10rpx;
}
.grid-item.data-v-1cf27b2a {
  position: relative;
  overflow: hidden;
}
.grid-mask.data-v-1cf27b2a {
  position: absolute;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  display: flex;
  flex-direction: column;
  justify-content: center;
  align-items: center;
  color: #fff;
  background-color: rgba(0, 0, 0, 0.4);
  width: 100%;
  height: 100%
}
.grid-cn.data-v-1cf27b2a {
  font-size: 30rpx;
  font-weight: 500;
}
.grid-en.data-v-1cf27b2a {
  font-size: 22rpx;
  margin-top: 8rpx;
  opacity: 0.8;
}
.video-list.data-v-1cf27b2a {
  display: flex;
  flex-direction: column;
  gap: 30rpx;
}
.video-item.data-v-1cf27b2a {
  border-radius: 12rpx;
  overflow: hidden;
}
.video-player.data-v-1cf27b2a {
  width: 100%;
