  margin-bottom: 8rpx;
}

/* 工作室名称区域 */
.title-section.data-v-1cf27b2a {
  text-align: center;
  margin-top: 80rpx;
}
.studio-name.data-v-1cf27b2a {
  font-size: 36rpx;
  font-weight: 600;
  color: #333333;
