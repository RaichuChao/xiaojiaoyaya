}
.contact-item.data-v-1cf27b2a {
  display: flex;
  align-items: center;
  padding: 30rpx 20rpx;
  border-bottom: 1rpx solid #e5e5e5;
  /* 提升点击区域 + 点击反馈 */
  cursor: pointer;
}
.contact-item.data-v-1cf27b2a:active {
  background-color: #f5f5f5;
}
.icon-wrap.data-v-1cf27b2a{
  width: 180rpx;
  height: 80rpx;
  /* 圆形关键 */
  border-radius: 50%;
  background-color: #ffffff;
  box-shadow: 0 4rpx 16rpx rgba(0, 0, 0, 0.12);
  margin-right: 30rpx;
  
  /* 让内部图标居中 */
  display: flex;
  align-items: center;
  justify-content: center;
}
.icon-inner.data-v-1cf27b2a {
  width: 40rpx;
  height: 40rpx;
  flex-shrink: 0; /* 禁止压缩变形 */
}
